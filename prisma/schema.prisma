generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reporte {
  id               String   @id @default(cuid())
  fecha            DateTime @default(now())
  mes              String
  anio             Int
  ingresosTotales  Float
  gastosOperativos Float
  gananciaNeta     Float
  detallesExtra    String   // Storing JSON as String for SQLite compatibility
}
